<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment"
    >

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.jasper.prudibel.fragment.SplashFragment"
        tools:layout="@layout/fragment_splash"
        >
        <action
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true"
            app:destination="@id/messagesFragment"
            android:id="@+id/action_splashFragment_to_messagesFragment"
            />
        <action
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true"
            app:destination="@id/authFragment"
            android:id="@+id/action_splashFragment_to_authFragment"
            />
    </fragment>

    <fragment
        android:id="@+id/messagesFragment"
        android:name="com.jasper.prudibel.fragment.MessagesFragment"
        android:label="@string/app_name"
        tools:layout="@layout/fragment_messages"
        />

    <fragment
        android:id="@+id/authFragment"
        android:name="com.jasper.prudibel.fragment.AuthFragment"
        android:label="@string/Log_in"
        tools:layout="@layout/fragment_auth"
        >
        <action
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true"
            app:destination="@id/messagesFragment"
            android:id="@+id/action_authFragment_to_messagesFragment"
            />
        <action
            android:id="@+id/action_authFragment_to_registerFragment"
            app:destination="@+id/registerFragment"
            />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.jasper.prudibel.fragment.RegisterFragment"
        android:label="@string/Register"
        tools:layout="@layout/fragment_register"
        >
        <action
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true"
            app:destination="@id/messagesFragment"
            android:id="@+id/action_registerFragment_to_messagesFragment"
            />
    </fragment>

</navigation>