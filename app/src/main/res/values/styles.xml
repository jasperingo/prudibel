<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="TextInputLayoutStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginEnd">@dimen/large</item>
        <item name="android:layout_marginStart">@dimen/large</item>
        <item name="android:layout_marginBottom">@dimen/large</item>
        <item name="boxStrokeColor">@color/text_input</item>
        <item name="boxStrokeWidth">@dimen/xxxSmall</item>
        <item name="boxBackgroundMode">outline</item>
        <item name="boxCornerRadiusTopEnd">@dimen/small</item>
        <item name="boxCornerRadiusTopStart">@dimen/small</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/small</item>
        <item name="boxCornerRadiusBottomStart">@dimen/small</item>
        <item name="boxBackgroundColor">?attr/colorSurface</item>
    </style>

    <style name="TextInputStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:paddingBottom">@dimen/medium</item>
    </style>

    <style name="ButtonStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:padding">@dimen/medium</item>
        <item name="android:layout_marginEnd">@dimen/large</item>
        <item name="android:layout_marginStart">@dimen/large</item>
        <item name="cornerRadius">@dimen/small</item>
    </style>

    <style name="AuthNavButtonStyle" parent="@style/Widget.AppCompat.Button.Borderless">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">@dimen/medium</item>
        <item name="android:background">@color/white</item>
        <item name="android:textColor">?attr/colorSecondary</item>
        <item name="textAllCaps">false</item>
        <item name="backgroundTint">@color/white</item>
    </style>

    <style name="MessageItem">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:maxWidth">250dp</item>
        <item name="android:layout_margin">@dimen/small</item>
        <item name="contentPadding">@dimen/xSmall</item>
        <item name="cardElevation">@dimen/xSmall</item>
        <item name="cardCornerRadius">@dimen/small</item>
    </style>

</resources>
